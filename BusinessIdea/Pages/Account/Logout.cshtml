@page
@model BusinessIdea.Web.Pages.Account.LogoutModel
@{
    ViewData["Title"] = "Sign out";
}

<section class="auth-card">
    <h1>Sign out</h1>
    <p class="subtitle">Are you sure you want to sign out?</p>
    <form method="post">
        <button type="submit" class="btn btn-primary btn-block">Sign out</button>
    </form>
</section>
