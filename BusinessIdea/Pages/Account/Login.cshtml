@page
@model BusinessIdea.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign in";
}

<section class="auth-card">
    <h1>Welcome back</h1>
    <p class="subtitle">Sign in to share and discuss business ideas.</p>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="field">
            <label asp-for="Input.Email">Email</label>
            <input asp-for="Input.Email" autocomplete="username" placeholder="you@example.com" />
            <span asp-validation-for="Input.Email" class="field-error"></span>
        </div>

        <div class="field">
            <label asp-for="Input.Password">Password</label>
            <input asp-for="Input.Password" autocomplete="current-password" placeholder="••••••••" />
            <span asp-validation-for="Input.Password" class="field-error"></span>
        </div>

        <label class="checkbox-row">
            <input asp-for="Input.RememberMe" />
            <span>Remember me</span>
        </label>

        <button type="submit" class="btn btn-primary btn-block">Sign in</button>
    </form>

    <p class="auth-alt">
        New here? <a href="/Account/Register">Create an account</a>
    </p>
</section>
