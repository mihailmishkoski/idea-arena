@{
    var user = User?.Identity;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · BusinessIdea</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <a class="brand" href="/">💡 BusinessIdea</a>
        <nav class="site-nav">
            <a href="/swagger">API</a>
            @if (user?.IsAuthenticated == true)
            {
                <span class="nav-user">@User!.Identity!.Name</span>
                <form class="inline-form" method="post" action="/Account/Logout">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-ghost">Sign out</button>
                </form>
            }
            else
            {
                <a class="btn btn-ghost" href="/Account/Login">Sign in</a>
                <a class="btn btn-primary" href="/Account/Register">Get started</a>
            }
        </nav>
    </header>

    <main class="site-main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <span>Built with ASP.NET Core · Clean Architecture · CQRS</span>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
